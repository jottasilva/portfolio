# Configurações do Appwrite (Públicas)
NEXT_PUBLIC_APPWRITE_PROJECT_ID="seu_project_id_aqui"
NEXT_PUBLIC_APPWRITE_PROJECT_NAME="portfolio"
NEXT_PUBLIC_APPWRITE_ENDPOINT="https://seu-endpoint.site/v1"

# Chave de API Secreta (Apenas para SCRIPTS Admin / API Routes)
# ⚠️ NUNCA compartilhe ou commite esta chave real!
APPWRITE_API_KEY="sua_api_key_secreta_aqui"

# Configurações do Chatbot IA (Groq)
GROQ_API_KEY="sua_gsk_chave_aqui"
GROQ_MODEL="llama-3.3-70b-versatile"
